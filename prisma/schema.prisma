generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int        @id @default(autoincrement())
  mobile     String     @unique
  createdAt  DateTime   @default(now())

  // relation
  properties Property[]
}

model Otp {
  id        Int      @id @default(autoincrement())
  mobile    String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Property {
  id             Int      @id @default(autoincrement())

  /*
  =========================
  USER RELATION
  =========================
  */
  userId         Int
  user           User     @relation(fields: [userId], references: [id])

  /*
  =========================
  BASIC INFO
  =========================
  */
  city           String
  propertyType   String
  propertyType2  String   @default("")

  propertyName   String?
  category       String?
  ownershipType  String?
  bhkType        String?

  /*
  =========================
  PROPERTY DETAILS
  =========================
  */
  floor          Int?
  totalFloor     Int?
  description    String?

  builtUpArea    Float?
  propertyAge    String?
  facing         String?
  noticePeriod   Int?
  occupancy      String?
  availableFrom  DateTime?

  /*
  =========================
  SHARING / TENANT
  =========================
  */
  sharingType      Json?
  preferredTenant  Json?

  /*
  =========================
  RULES
  =========================
  */
  rulesAndRegulation String?

  /*
  =========================
  ROOM TYPES
  =========================
  */
  roomType        Json?

  /*
  =========================
  LOCATION
  =========================
  */
  location        String?
  street          String?
  locality        String?
  landmark        String?
  pincode         String?

  /*
  =========================
  AMENITIES
  =========================
  */
  parking          Json?
  restrictions     Json?
  furnishing       Json?
  societyAmenities Json?

  foodIncluded     Boolean?
  petAllowed       Boolean?
  nonVegAllowed    Boolean?
  gatedCommunity   Boolean?
  gateSecurity     Boolean?

  noOfFloors       String?
  noOfBalcony      String?

  /*
  =========================
  PRICE
  =========================
  */
  rent           Float?
  maintenance    Float?
  deposit        Float?
  rentNegotiable Boolean?

  /*
  =========================
  MEDIA
  =========================
  */
  images         String[] @default([])
  video          String?

  /*
  =========================
  CONTACT
  =========================
  */
  contactName    String?
  mobileNo       String?
  repliesWithin  String?
  whatsapp       Boolean?

  /*
  =========================
  STATUS
  =========================
  */
  currentStep    Int      @default(1)
  isDraft        Boolean  @default(true)

  /*
  =========================
  TIMESTAMPS
  =========================
  */
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}